{
  "name": "gitcut",
  "version": "2.0.1",
  "description": "A modern, interactive Git CLI to simplify your daily workflows",
  "keywords": [
    "checkout",
    "cherry-pick",
    "git",
    "merge",
    "query",
    "rebase",
    "shortcut",
    "stats",
    "submit"
  ],
  "license": "MIT",
  "author": "dingff",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dingff/gitcut.git"
  },
  "bin": {
    "gt": "bin/index"
  },
  "files": [
    "bin/",
    "index.js",
    "config.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "release": "release-it --only-version",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "release-it": "^19.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}",
      "web": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md",
        "ignoreRecommendedBump": true
      }
    }
  }
}
