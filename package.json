{
  "name": "gitcut",
  "version": "2.1.7",
  "description": "A modern, interactive Git CLI to simplify your daily workflows",
  "keywords": [
    "checkout",
    "cherry-pick",
    "git",
    "merge",
    "query",
    "rebase",
    "shortcut",
    "stats",
    "submit"
  ],
  "license": "MIT",
  "author": "dingff",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dingff/gitcut.git"
  },
  "bin": {
    "gt": "bin/index"
  },
  "files": [
    "bin/",
    "index.js"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "release": "release-it --only-version",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "llm-local": "^0.3.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "release-it": "^20.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "v${version}",
      "web": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md",
        "ignoreRecommendedBump": true
      }
    }
  }
}
